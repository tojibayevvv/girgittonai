# PostgreSQL ulanish manzili (Railway'dan oladigan URL shu yerga)
DATABASE_URL="postgresql://user:password@localhost:5432/girgitton?schema=public"

# JWT
JWT_SECRET="change-this-super-secret-key"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000

# CORS uchun ruxsat etilgan frontend manzillari (vergul bilan ajratiladi)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"

# AI ovozli ofitsiant — Anthropic (Claude) API kaliti
# Kalitni https://console.anthropic.com dan oling
ANTHROPIC_API_KEY="sk-ant-..."
# Ixtiyoriy: model (default — tez va arzon Haiku)
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# Aisha AI — sof o'zbek ovozi / klonlangan ovoz (TTS). https://aisha.group
AISHA_API_KEY=""
# Klonlangan ovoz id si (Space > Voices, "READY" bo'lganda). Bo'sh bo'lsa Gulnoza.
AISHA_VOICE_ID=""
AISHA_MODEL="Gulnoza"
AISHA_MOOD="Neutral"
AISHA_SPEED="0.9"
AISHA_LANGUAGE="uz"
