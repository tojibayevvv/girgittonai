// GirgittonAI — SaaS restoran buyurtma platformasi
// Multi-tenant: har bir Restaurant alohida ijarachi (tenant).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enum'lar ----------

enum UserRole {
  SUPER_ADMIN // platforma egasi (admin app)
  RESTAURANT_ADMIN // restoran egasi/admini (adminpanel app)
  STAFF // ofitsiant/oshpaz (keyinchalik)
}

enum RestaurantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

enum OrderStatus {
  PENDING // yangi tushdi
  ACCEPTED // qabul qilindi
  PREPARING // tayyorlanmoqda
  READY // tayyor
  SERVED // berildi
  COMPLETED // yopildi/to'landi
  CANCELLED // bekor qilindi
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

// ---------- Foydalanuvchilar ----------

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  fullName     String
  role         UserRole    @default(RESTAURANT_ADMIN)
  isActive     Boolean     @default(true)
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([restaurantId])
}

// ---------- SaaS: tariflar, obunalar, to'lovlar ----------

model Plan {
  id            String         @id @default(uuid())
  name          String         @unique // Free, Basic, Pro
  priceMonthly  Decimal        @default(0) @db.Decimal(12, 2)
  maxTables     Int            @default(10)
  maxProducts   Int            @default(50)
  features      Json?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(uuid())
  restaurantId     String             @unique
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan               @relation(fields: [planId], references: [id])
  status           SubscriptionStatus @default(TRIALING)
  currentPeriodEnd DateTime?
  payments         Payment[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Payment {
  id             String        @id @default(uuid())
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("UZS")
  status         PaymentStatus @default(PENDING)
  provider       String? // payme, click, stripe ...
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  @@index([subscriptionId])
}

// ---------- Restoran (tenant) ----------

model Restaurant {
  id           String           @id @default(uuid())
  name         String
  slug         String           @unique
  logoUrl      String?
  phone        String?
  address      String?
  currency     String           @default("UZS")
  status       RestaurantStatus @default(TRIAL)
  users        User[]
  categories   Category[]
  products     Product[]
  tables       Table[]
  orders       Order[]
  subscription Subscription?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// ---------- Menyu ----------

model Category {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  products     Product[]
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}

model Product {
  id           String      @id @default(uuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name         String
  description  String?
  price        Decimal     @db.Decimal(12, 2)
  imageUrl     String?
  isAvailable  Boolean     @default(true)
  isSpicy      Boolean     @default(false) // AI tavsiyalari uchun belgilar
  tags         String[] // vegetarian, halal, achchiq, shirin ... (AI uchun)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]

  @@index([restaurantId])
  @@index([categoryId])
}

// ---------- Stollar (QR) ----------

model Table {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String // "Stol 1"
  code         String     @unique // QR ichidagi noyob token
  isActive     Boolean    @default(true)
  orders       Order[]
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}

// ---------- Buyurtmalar ----------

model Order {
  id           String      @id @default(uuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableId      String?
  table        Table?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  orderNumber  Int // restoran ichida ketma-ket raqam
  status       OrderStatus @default(PENDING)
  total        Decimal     @default(0) @db.Decimal(12, 2)
  note         String?
  items        OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([restaurantId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Mahsulot o'chirilsa null bo'ladi; nom/narx pastda snapshot qilingan
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String // buyurtma paytidagi nom (snapshot)
  price     Decimal  @db.Decimal(12, 2) // buyurtma paytidagi narx (snapshot)
  quantity  Int      @default(1)

  @@index([orderId])
}
